# ⚡ Backend Environment Configurations
PORT=8000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# 🔐 Security Secrets
JWT_ACCESS_SECRET=secret-primary-access-v1-2026
JWT_REFRESH_SECRET=secret-refresh-access-v1-2026
BCRYPT_SALT=12

# 🐘 PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=udaan

# ⚡ Redis Configuration
REDIS_URL=redis://localhost:6379

# 📡 Optional: File Storage (AWS/Cloudflare)
AWS_S3_BUCKET=udaan-assets
AWS_S3_KEY=
AWS_S3_SECRET=
AWS_S3_REGION=ap-south-1
